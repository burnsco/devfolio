---
import { Icon } from 'astro-icon/components';

interface SkillGroup {
	category: string;
	items: { name: string; icon: string }[];
}

interface Props {
	skills: SkillGroup[];
}

const { skills } = Astro.props;
---

<section
	id="vdf-skills"
	class="px-8 py-20 lg:px-24 bg-[var(--bg-section)] border-y border-[var(--border-hairline)] scroll-mt-20"
>
	<div class="mb-12 vdf-reveal">
		<p class="mb-2 font-mono text-sm tracking-widest text-red-500 uppercase">
			<span class="text-red-500/60">02 —</span> Capabilities
		</p>
		<h2 class="text-3xl font-black tracking-tighter uppercase sm:text-4xl md:text-6xl">
			Skills
		</h2>
	</div>
	<div class="grid gap-12 md:grid-cols-2 xl:grid-cols-4">
		{skills.map((group) => (
			<div class="vdf-reveal">
				<h3 class="pb-3 mb-6 font-mono text-[11px] tracking-[0.3em] sm:tracking-[0.4em] text-red-500 uppercase border-b border-[var(--border-hairline)] font-bold">
					{group.category}
				</h3>
				<ul class="grid grid-cols-3 gap-3">
					{group.items.map((skill) => (
						<li
							class="vdf-stagger group/skill"
							title={skill.name}
						>
							<div class="relative flex flex-col items-center justify-center p-3 transition-all duration-500 rounded-lg bg-[var(--fill-tint-2)] border border-[var(--border-hairline)] hover:border-[var(--border-muted)] hover:bg-[var(--fill-tint-5)] group-hover/skill:-translate-y-1">
								<Icon
									name={skill.icon}
									class="w-8 h-8 mb-2 transition-all duration-500 group-hover/skill:scale-110 grayscale group-hover/skill:grayscale-0 opacity-40 group-hover/skill:opacity-100"
								/>
								<span class="text-[10px] leading-tight text-center uppercase tracking-wider sm:tracking-widest text-[var(--text-tertiary)] group-hover/skill:text-[var(--text-primary)] transition-colors duration-500">
									{skill.name}
								</span>
							</div>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>
</section>
