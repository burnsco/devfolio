---
import SideNav from "./SideNav.astro";

interface Props {
	navItems: { id: string; label: string }[];
}

const { navItems } = Astro.props;
---

<header
	id="vdf-hero"
	class="relative flex flex-col justify-center h-screen px-8 pt-20 lg:px-24"
>
	<SideNav navItems={navItems} />

	<p data-hero-item="0" class="text-red-500 uppercase tracking-[0.3em] sm:tracking-[0.5em] text-[11px] sm:text-xs font-bold mb-8 opacity-80">
		Full-Stack Developer & Systems Enthusiast
	</p>
	<h1 data-hero-item="1" class="vdf-skew text-[13vw] lg:text-[11vw] leading-[0.8] font-black tracking-tighter uppercase mb-4">
		Corey
		<br />
		<span class="outline-title">Burns</span>
	</h1>
	<div data-hero-item="2" class="flex items-center gap-6 mt-12">
		<div class="w-16 h-px bg-red-500"></div>
		<p class="max-w-md uppercase tracking-[0.15em] sm:tracking-[0.2em] text-xs leading-relaxed text-neutral-400 font-medium">
			Crafting digital experiences where performance meets precision.
		</p>
	</div>
	<div data-hero-item="3" class="flex gap-6 mt-8">
		<a
			href="#vdf-projects"
			data-scroll-to="projects"
			class="px-8 py-3 text-sm font-bold tracking-widest text-white uppercase transition-colors duration-300 transform bg-red-600 hover:bg-red-700 hover:-skew-x-6"
		>
			View Work
		</a>
		<a
			href="#vdf-contact"
			data-scroll-to="contact"
			class="px-8 py-3 text-sm font-bold tracking-widest text-white uppercase transition-all duration-300 border border-white/20 hover:border-red-500 hover:text-red-500"
		>
			Contact
		</a>
	</div>

	<div id="hero-scroll-indicator" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
		<span class="text-[11px] uppercase tracking-[0.4em] text-white/30 font-bold">Scroll</span>
		<svg
			class="w-5 h-5 text-red-500 animate-bounce"
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
			stroke-width="2.5"
			aria-hidden="true"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
		</svg>
	</div>
</header>
