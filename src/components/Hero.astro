---
import SideNav from "./SideNav";

interface Props {
	navItems: { id: string; label: string }[];
}

const { navItems } = Astro.props;
---

<header
	id="vdf-hero"
	class="relative flex flex-col justify-center h-screen px-8 pt-20 lg:px-24"
>
	<SideNav client:load navItems={navItems} />

	<p class="text-red-500 uppercase tracking-[0.5em] text-[10px] font-bold mb-8 opacity-80">
		Full-Stack Developer & Systems Enthusiast
	</p>
	<h1 class="text-[13vw] lg:text-[11vw] leading-[0.8] font-black tracking-tighter uppercase mb-4">
		Corey
		<br />
		<span class="outline-title">Burns</span>
	</h1>
	<div class="vdf-reveal flex items-center gap-6 mt-12">
		<div class="w-16 h-px bg-red-500"></div>
		<p class="max-w-md uppercase tracking-[0.2em] text-[11px] leading-relaxed text-neutral-400 font-medium">
			Crafting digital experiences where performance meets precision.
		</p>
	</div>
	<div class="flex gap-6 mt-8">
		<button
			type="button"
			data-scroll-to="projects"
			class="px-8 py-3 text-sm font-bold tracking-widest text-white uppercase transition-colors duration-300 transform bg-red-600 hover:bg-red-700 hover:-skew-x-6"
		>
			View Work
		</button>
		<button
			type="button"
			data-scroll-to="contact"
			class="px-8 py-3 text-sm font-bold tracking-widest text-white uppercase transition-all duration-300 border border-white/20 hover:border-red-500 hover:text-red-500"
		>
			Contact
		</button>
	</div>
</header>
