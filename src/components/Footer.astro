---
const year = new Date().getFullYear();
---
<footer class="px-8 py-12 bg-[var(--bg-section)] border-t border-[var(--border-hairline)]">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6 text-[11px] font-mono uppercase tracking-[0.2em] sm:tracking-[0.3em] text-[var(--text-tertiary)]">
        <p>© {year} Corey Burns</p>
        <button
            type="button"
            id="back-to-top"
            class="flex items-center gap-2 hover:text-red-500 transition-colors duration-300 group"
            aria-label="Back to top"
        >
            <svg
                class="w-3 h-3 transition-transform duration-300 group-hover:-translate-y-0.5"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
            >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
            </svg>
            Back to Top
        </button>
        <p>Built with Astro & GSAP</p>
        <p>Crafted in Canada</p>
    </div>
</footer>

<script>
    document.getElementById("back-to-top")?.addEventListener("click", () => {
        const heroEl = document.getElementById("vdf-hero");
        if (heroEl) {
            heroEl.scrollIntoView({ behavior: "smooth" });
        }
    });
</script>
