---
interface Props {
	navItems: { id: string; label: string }[];
	activeSection?: string;
}

const { navItems, activeSection = "hero" } = Astro.props;
---

<nav
	id="main-nav"
	aria-label="Primary"
	class="group fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-6 md:px-12 md:py-8 transition-all duration-300"
>
	<div id="nav-backdrop" class="absolute inset-0 bg-neutral-950/80 backdrop-blur-md border-b border-white/5 opacity-0 transition-opacity duration-300 pointer-events-none"></div>
	
	<a
		href="#vdf-hero"
		data-scroll-to="hero"
		class="relative z-10 text-2xl font-black tracking-tighter uppercase text-white mix-blend-difference"
	>
		CB<span class="text-red-500">.</span>
	</a>
	
	<div class="relative z-10 items-center hidden md:flex gap-10">
		{navItems.map((item) => (
			<a
				href={`#vdf-${item.id}`}
				data-scroll-to={item.id}
				data-nav-link={item.id}
				class={`text-[11px] uppercase tracking-[0.3em] font-bold transition-all duration-300 ${
					activeSection === item.id
						? "text-red-500"
						: "text-white/60 hover:text-white"
				} hover:tracking-[0.4em]`}
			>
				{item.label}
			</a>
		))}
	</div>

	<button
		type="button"
		id="menu-toggle"
		class="relative z-10 flex flex-col gap-1.5 md:hidden p-2 group"
		aria-label="Toggle Menu"
		aria-controls="mobile-menu"
		aria-expanded="false"
	>
		<span class="menu-bar w-6 h-0.5 bg-white transition-all duration-300"></span>
		<span class="menu-bar w-6 h-0.5 bg-white transition-all duration-300"></span>
		<span class="menu-bar w-6 h-0.5 bg-white transition-all duration-300"></span>
	</button>
</nav>

<button
	type="button"
	id="menu-overlay"
	class="fixed inset-0 z-50 transition-opacity pointer-events-none bg-neutral-950/90 backdrop-blur-md opacity-0 border-none w-full h-full text-transparent cursor-default"
	aria-label="Close Menu"
	aria-hidden="true"
	hidden
></button>

<nav
	id="mobile-menu"
	aria-label="Mobile"
	aria-hidden="true"
	hidden
	inert
	class="fixed top-0 right-0 bottom-0 w-[80%] max-w-[400px] bg-neutral-900 z-50 translate-x-full flex flex-col justify-center px-12 border-l border-white/5"
>
	<div class="flex flex-col gap-8">
		{navItems.map((item, index) => (
			<a
				href={`#vdf-${item.id}`}
				data-scroll-to={item.id}
				data-mobile-link={item.id}
				class={`mobile-link text-left text-3xl font-black uppercase tracking-tighter transition-colors duration-300 ${
					activeSection === item.id ? "text-red-500" : "text-white"
				}`}
			>
				<span class="mr-4 text-xs font-mono text-red-500">
					{String(index + 1).padStart(2, "0")}
				</span>
				{item.label}
			</a>
		))}
	</div>

	<div class="absolute bottom-12 left-12 right-12">
		<div class="w-full h-px mb-8 bg-white/5"></div>
		<div class="flex gap-6">
			<a
				href="https://github.com/burnsco"
				target="_blank"
				rel="noopener noreferrer"
				class="opacity-50 hover:opacity-100 transition-opacity"
			>
				<img
					src="/icons/github.svg"
					alt="GitHub"
					class="w-6 h-6 invert"
				/>
			</a>
			<a
				href="https://linkedin.com/in/corey-burns"
				target="_blank"
				rel="noopener noreferrer"
				class="opacity-50 hover:opacity-100 transition-opacity"
			>
				<img
					src="/icons/linkedin.svg"
					alt="LinkedIn"
					class="w-6 h-6 invert"
				/>
			</a>
		</div>
	</div>
</nav>

<script>
	import gsap from "gsap";

	const menuToggle = document.getElementById("menu-toggle");
	const menuOverlay = document.getElementById("menu-overlay") as HTMLButtonElement | null;
	const mobileMenu = document.getElementById("mobile-menu") as HTMLElement | null;
	const menuBars = document.querySelectorAll(".menu-bar");
	const mobileLinks = document.querySelectorAll(".mobile-link");
	const navLinks = document.querySelectorAll("[data-nav-link]");
	
	let isMenuOpen = false;
	let previousOverflow = "";

	const setMenuAccessibility = (open: boolean) => {
		menuToggle?.setAttribute("aria-expanded", String(open));
		menuOverlay?.toggleAttribute("hidden", !open);
		menuOverlay?.setAttribute("aria-hidden", String(!open));

		if (!mobileMenu) return;

		mobileMenu.toggleAttribute("hidden", !open);
		mobileMenu.toggleAttribute("inert", !open);
		mobileMenu.setAttribute("aria-hidden", String(!open));
	};

	const toggleMenu = () => {
		if (!menuToggle || !menuOverlay || !mobileMenu) return;
		isMenuOpen = !isMenuOpen;
		
		if (isMenuOpen) {
			previousOverflow = document.body.style.overflow;
			document.body.style.overflow = "hidden";
			setMenuAccessibility(true);
			
			// Button animation
			gsap.to(menuBars[0], { rotate: 45, y: 8, backgroundColor: "#ef4444", duration: 0.3 });
			gsap.to(menuBars[1], { opacity: 0, duration: 0.3 });
			gsap.to(menuBars[2], { rotate: -45, y: -8, backgroundColor: "#ef4444", duration: 0.3 });

			gsap.to(menuOverlay, {
				opacity: 1,
				pointerEvents: "auto",
				duration: 0.5,
				ease: "power3.out",
			});
			gsap.to(mobileMenu, {
				x: 0,
				duration: 0.6,
				ease: "power4.out",
			});
			gsap.fromTo(
				mobileLinks,
				{ y: 50, opacity: 0 },
				{
					y: 0,
					opacity: 1,
					duration: 0.8,
					stagger: 0.1,
					ease: "power4.out",
					delay: 0.2,
				},
			);
		} else {
			document.body.style.overflow = previousOverflow;
			
			// Button animation
			gsap.to(menuBars[0], { rotate: 0, y: 0, backgroundColor: "#ffffff", duration: 0.3 });
			gsap.to(menuBars[1], { opacity: 1, duration: 0.3 });
			gsap.to(menuBars[2], { rotate: 0, y: 0, backgroundColor: "#ffffff", duration: 0.3 });

			gsap.to(mobileMenu, {
				x: "100%",
				duration: 0.5,
				ease: "power3.in",
			});
			gsap.to(menuOverlay, {
				opacity: 0,
				pointerEvents: "none",
				duration: 0.5,
				ease: "power3.in",
				onComplete: () => {
					setMenuAccessibility(false);
				},
			});
		}
	};

	const closeMenu = () => {
		if (isMenuOpen) toggleMenu();
	};

	menuToggle?.addEventListener("click", toggleMenu);
	menuOverlay?.addEventListener("click", closeMenu);
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeMenu();
		}
	});

	// Nav backdrop on scroll
	const navBackdrop = document.getElementById("nav-backdrop");
	const heroEl = document.getElementById("vdf-hero");

	const updateBackdrop = () => {
		const heroHeight = heroEl?.offsetHeight ?? window.innerHeight;
		if (window.scrollY > heroHeight * 0.15) {
			navBackdrop?.classList.replace("opacity-0", "opacity-100");
		} else {
			navBackdrop?.classList.replace("opacity-100", "opacity-0");
		}
	};

	window.addEventListener("scroll", updateBackdrop, { passive: true });
	updateBackdrop();

	// Handle section changes from index.astro
	window.addEventListener("sectionChange", ((e: CustomEvent<string>) => {
		const activeId = e.detail;

		navLinks.forEach((link) => {
			const id = link.getAttribute("data-nav-link");
			if (id === activeId) {
				link.classList.add("text-red-500");
				link.classList.remove("text-white/60");
			} else {
				link.classList.remove("text-red-500");
				link.classList.add("text-white/60");
			}
		});

		mobileLinks.forEach((link) => {
			const id = link.getAttribute("data-mobile-link");
			if (id === activeId) {
				link.classList.add("text-red-500");
				link.classList.remove("text-white");
			} else {
				link.classList.remove("text-red-500");
				link.classList.add("text-white");
			}
		});
	}) as EventListener);

	// Smooth scroll + close menu on link click
	document.querySelectorAll("[data-scroll-to]").forEach((link) => {
		link.addEventListener("click", (e) => {
			e.preventDefault();
			const targetId = link.getAttribute("data-scroll-to");
			const target = document.getElementById(`vdf-${targetId}`);
			if (target) {
				target.scrollIntoView({ behavior: "smooth" });
			}
			if (isMenuOpen) closeMenu();
		});
	});

	setMenuAccessibility(false);
</script>
