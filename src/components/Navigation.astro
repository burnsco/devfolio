---
interface Props {
	navItems: { id: string; label: string }[];
	activeSection?: string;
}

const { navItems, activeSection = "hero" } = Astro.props;
---

<nav
	id="main-nav"
	aria-label="Primary"
	class="group fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-6 md:px-12 md:py-8 transition-all duration-300"
>
	<div id="nav-backdrop" class="absolute inset-0 bg-[var(--bg-nav)] backdrop-blur-md border-b border-[var(--border-hairline)] opacity-0 transition-opacity duration-300 pointer-events-none"></div>

	<a
		href="#vdf-hero"
		data-scroll-to="hero"
		class="relative z-10 text-2xl font-black tracking-tighter uppercase text-[var(--text-primary)]"
	>
		CB<span class="text-red-500">.</span>
	</a>

	<div class="relative z-10 items-center hidden md:flex gap-8 lg:gap-10">
		{navItems.map((item) => (
			<a
				href={`#vdf-${item.id}`}
				data-scroll-to={item.id}
				data-nav-link={item.id}
				class={`text-[11px] uppercase tracking-[0.3em] font-bold transition-all duration-300 ${
					activeSection === item.id
						? "text-red-500"
						: "text-[var(--text-secondary)] hover:text-[var(--text-primary)]"
				} hover:tracking-[0.4em]`}
			>
				{item.label}
			</a>
		))}
		<button
			type="button"
			data-cmdk-trigger
			aria-label="Open command palette"
			class="inline-flex items-center gap-2 px-2.5 py-1 rounded-md border border-[var(--border-muted)] bg-[var(--fill-tint-5)] hover:border-red-500/40 hover:bg-red-500/5 transition-colors duration-300 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--text-tertiary)] hover:text-[var(--text-primary)]"
		>
			<kbd class="font-mono text-[11px]">⌘K</kbd>
		</button>
		<button
			type="button"
			data-theme-toggle
			aria-label="Toggle color theme"
			class="relative inline-flex items-center justify-center w-8 h-8 rounded-md border border-[var(--border-muted)] bg-[var(--fill-tint-5)] hover:border-red-500/40 hover:bg-red-500/5 transition-colors duration-300 text-[var(--text-tertiary)] hover:text-[var(--text-primary)]"
		>
			<svg data-theme-icon="dark" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
			</svg>
			<svg data-theme-icon="light" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4" />
				<path d="M12 2v2" />
				<path d="M12 20v2" />
				<path d="m4.93 4.93 1.41 1.41" />
				<path d="m17.66 17.66 1.41 1.41" />
				<path d="M2 12h2" />
				<path d="M20 12h2" />
				<path d="m6.34 17.66-1.41 1.41" />
				<path d="m19.07 4.93-1.41 1.41" />
			</svg>
		</button>
	</div>

	<div class="relative z-10 flex items-center gap-2 md:hidden">
		<button
			type="button"
			data-theme-toggle
			aria-label="Toggle color theme"
			class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-[var(--border-muted)] bg-[var(--fill-tint-5)] text-[var(--text-tertiary)]"
		>
			<svg data-theme-icon="dark" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
			</svg>
			<svg data-theme-icon="light" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="12" cy="12" r="4" />
				<path d="M12 2v2" />
				<path d="M12 20v2" />
				<path d="m4.93 4.93 1.41 1.41" />
				<path d="m17.66 17.66 1.41 1.41" />
				<path d="M2 12h2" />
				<path d="M20 12h2" />
				<path d="m6.34 17.66-1.41 1.41" />
				<path d="m19.07 4.93-1.41 1.41" />
			</svg>
		</button>
		<button
			type="button"
			id="menu-toggle"
			class="flex flex-col gap-1.5 p-2 group"
			aria-label="Toggle Menu"
			aria-controls="mobile-menu"
			aria-expanded="false"
		>
			<span class="menu-bar w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300"></span>
			<span class="menu-bar w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300"></span>
			<span class="menu-bar w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300"></span>
		</button>
	</div>
</nav>

<button
	type="button"
	id="menu-overlay"
	class="fixed inset-0 z-50 transition-opacity pointer-events-none bg-[var(--bg-overlay-menu)] backdrop-blur-md opacity-0 border-none w-full h-full text-transparent cursor-default"
	aria-label="Close Menu"
	aria-hidden="true"
	hidden
></button>

<nav
	id="mobile-menu"
	aria-label="Mobile"
	aria-hidden="true"
	hidden
	inert
	class="fixed top-0 right-0 bottom-0 w-[80%] max-w-[400px] bg-[var(--bg-surface-raised)] z-50 translate-x-full flex flex-col justify-center px-12 border-l border-[var(--border-hairline)]"
>
	<div class="flex flex-col gap-8">
		{navItems.map((item, index) => (
			<a
				href={`#vdf-${item.id}`}
				data-scroll-to={item.id}
				data-mobile-link={item.id}
				class={`mobile-link text-left text-3xl font-black uppercase tracking-tighter transition-colors duration-300 ${
					activeSection === item.id ? "text-red-500" : "text-[var(--text-primary)]"
				}`}
			>
				<span class="mr-4 text-xs font-mono text-red-500">
					{String(index + 1).padStart(2, "0")}
				</span>
				{item.label}
			</a>
		))}
	</div>

	<div class="absolute bottom-12 left-12 right-12">
		<div class="w-full h-px mb-8 bg-[var(--border-hairline)]"></div>
		<div class="flex gap-6">
			<a
				href="https://github.com/burnsco"
				target="_blank"
				rel="noopener noreferrer"
				class="opacity-50 hover:opacity-100 transition-opacity"
			>
				<img
					src="/icons/github.svg"
					alt="GitHub"
					class="w-6 h-6 icon-adaptive"
				/>
			</a>
			<a
				href="https://linkedin.com/in/corey-burns"
				target="_blank"
				rel="noopener noreferrer"
				class="opacity-50 hover:opacity-100 transition-opacity"
			>
				<img
					src="/icons/linkedin.svg"
					alt="LinkedIn"
					class="w-6 h-6 icon-adaptive"
				/>
			</a>
		</div>
	</div>
</nav>

<script>
	import gsap from "gsap";

	const menuToggle = document.getElementById("menu-toggle");
	const menuOverlay = document.getElementById("menu-overlay") as HTMLButtonElement | null;
	const mobileMenu = document.getElementById("mobile-menu") as HTMLElement | null;
	const menuBars = document.querySelectorAll(".menu-bar");
	const mobileLinks = document.querySelectorAll(".mobile-link");
	const navLinks = document.querySelectorAll("[data-nav-link]");
	
	let isMenuOpen = false;
	let previousOverflow = "";

	const setMenuAccessibility = (open: boolean) => {
		menuToggle?.setAttribute("aria-expanded", String(open));
		menuOverlay?.toggleAttribute("hidden", !open);
		menuOverlay?.setAttribute("aria-hidden", String(!open));

		if (!mobileMenu) return;

		mobileMenu.toggleAttribute("hidden", !open);
		mobileMenu.toggleAttribute("inert", !open);
		mobileMenu.setAttribute("aria-hidden", String(!open));
	};

	const toggleMenu = () => {
		if (!menuToggle || !menuOverlay || !mobileMenu) return;
		isMenuOpen = !isMenuOpen;
		
		if (isMenuOpen) {
			previousOverflow = document.body.style.overflow;
			document.body.style.overflow = "hidden";
			setMenuAccessibility(true);

			gsap.to(menuBars[0], { rotate: 45, y: 8, backgroundColor: "#ef4444", duration: 0.3 });
			gsap.to(menuBars[1], { opacity: 0, duration: 0.3 });
			gsap.to(menuBars[2], { rotate: -45, y: -8, backgroundColor: "#ef4444", duration: 0.3 });

			gsap.to(menuOverlay, {
				opacity: 1,
				pointerEvents: "auto",
				duration: 0.5,
				ease: "power3.out",
			});
			gsap.to(mobileMenu, {
				x: 0,
				duration: 0.6,
				ease: "power4.out",
			});
			gsap.fromTo(
				mobileLinks,
				{ y: 50, opacity: 0 },
				{
					y: 0,
					opacity: 1,
					duration: 0.8,
					stagger: 0.1,
					ease: "power4.out",
					delay: 0.2,
				},
			);
		} else {
			document.body.style.overflow = previousOverflow;

			const primary = getComputedStyle(document.documentElement).getPropertyValue("--text-primary").trim() || "#ffffff";
			gsap.to(menuBars[0], { rotate: 0, y: 0, backgroundColor: primary, duration: 0.3 });
			gsap.to(menuBars[1], { opacity: 1, duration: 0.3 });
			gsap.to(menuBars[2], { rotate: 0, y: 0, backgroundColor: primary, duration: 0.3 });

			gsap.to(mobileMenu, {
				x: "100%",
				duration: 0.5,
				ease: "power3.in",
			});
			gsap.to(menuOverlay, {
				opacity: 0,
				pointerEvents: "none",
				duration: 0.5,
				ease: "power3.in",
				onComplete: () => {
					setMenuAccessibility(false);
				},
			});
		}
	};

	const closeMenu = () => {
		if (isMenuOpen) toggleMenu();
	};

	menuToggle?.addEventListener("click", toggleMenu);
	menuOverlay?.addEventListener("click", closeMenu);
	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeMenu();
		}
	});

	const navBackdrop = document.getElementById("nav-backdrop");
	const heroEl = document.getElementById("vdf-hero");
	let heroHeight = heroEl?.offsetHeight ?? window.innerHeight;
	let backdropVisible: boolean | null = null;

	const updateBackdrop = () => {
		const visible = window.scrollY > heroHeight * 0.15;
		if (visible === backdropVisible) return;
		backdropVisible = visible;
		navBackdrop?.classList.replace(
			visible ? "opacity-0" : "opacity-100",
			visible ? "opacity-100" : "opacity-0",
		);
	};

	window.addEventListener("scroll", updateBackdrop, { passive: true });
	window.addEventListener(
		"resize",
		() => {
			heroHeight = heroEl?.offsetHeight ?? window.innerHeight;
			updateBackdrop();
		},
		{ passive: true },
	);
	updateBackdrop();

	window.addEventListener("sectionChange", ((e: CustomEvent<string>) => {
		const activeId = e.detail;

		navLinks.forEach((link) => {
			const id = link.getAttribute("data-nav-link");
			if (id === activeId) {
				link.classList.add("text-red-500");
				link.classList.remove("text-[var(--text-secondary)]");
			} else {
				link.classList.remove("text-red-500");
				link.classList.add("text-[var(--text-secondary)]");
			}
		});

		mobileLinks.forEach((link) => {
			const id = link.getAttribute("data-mobile-link");
			if (id === activeId) {
				link.classList.add("text-red-500");
				link.classList.remove("text-[var(--text-primary)]");
			} else {
				link.classList.remove("text-red-500");
				link.classList.add("text-[var(--text-primary)]");
			}
		});
	}) as EventListener);

	document.querySelectorAll("[data-scroll-to]").forEach((link) => {
		link.addEventListener("click", (e) => {
			e.preventDefault();
			const targetId = link.getAttribute("data-scroll-to");
			const target = document.getElementById(`vdf-${targetId}`);
			if (target) {
				target.scrollIntoView({ behavior: "smooth" });
			}
			if (isMenuOpen) closeMenu();
		});
	});

	setMenuAccessibility(false);

	const themeToggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
	const darkIcons = document.querySelectorAll<HTMLElement>('[data-theme-icon="dark"]');
	const lightIcons = document.querySelectorAll<HTMLElement>('[data-theme-icon="light"]');
	const systemMatcher = window.matchMedia("(prefers-color-scheme: light)");

	const syncThemeUI = () => {
		const isLight = document.documentElement.classList.contains("light");
		darkIcons.forEach((el) => el.classList.toggle("hidden", isLight));
		lightIcons.forEach((el) => el.classList.toggle("hidden", !isLight));
		themeToggles.forEach((btn) => {
			btn.setAttribute("aria-label", isLight ? "Switch to dark theme" : "Switch to light theme");
			btn.setAttribute("aria-pressed", String(isLight));
		});
	};

	const applyTheme = (theme: "light" | "dark") => {
		document.documentElement.classList.toggle("light", theme === "light");
		syncThemeUI();
	};

	const onSystemChange = (e: MediaQueryListEvent) => {
		if (localStorage.getItem("theme")) return; // explicit user choice wins
		applyTheme(e.matches ? "light" : "dark");
	};

	themeToggles.forEach((btn) => {
		btn.addEventListener("click", () => {
			const next: "light" | "dark" = document.documentElement.classList.contains("light")
				? "dark"
				: "light";
			try {
				localStorage.setItem("theme", next);
			} catch {}
			applyTheme(next);
		});
	});

	systemMatcher.addEventListener("change", onSystemChange);
	syncThemeUI();
</script>
