---
import { skills as skillGroups } from "../data/skills";
import { hasLiveUrl } from "../utils/projects";
import { Icon } from "astro-icon/components";

interface Project {
	id: string;
	title: string;
	category: string;
	color: string;
	tech: string;
	description: string;
	url: string;
	repo: string;
	featured?: boolean;
}

interface ProjectCategory {
	name: string;
	projects: Project[];
}

interface Props {
	projectCategories?: ProjectCategory[];
    projects?: Project[];
}

const { projectCategories, projects } = Astro.props;

// Flatten the projects and add parent category for filtering
// Handle both categorized and flat project lists
let allProjects: (Project & { parentCategory: string })[] = [];
let categories: string[] = ["All"];

if (projectCategories && Array.isArray(projectCategories)) {
    allProjects = projectCategories.flatMap(cat => 
        cat.projects.map(p => ({ 
            ...p, 
            parentCategory: cat.name 
        }))
    );
    categories = ["All", ...projectCategories.map(cat => cat.name)];
} else if (projects && Array.isArray(projects)) {
    // If a flat list is provided, group by their internal category for filtering
    allProjects = projects.map(p => ({
        ...p,
        parentCategory: p.category
    }));
    const uniqueCategories = [...new Set(projects.map(p => p.category))];
    categories = ["All", ...uniqueCategories];
}

allProjects.sort(
    (a, b) => Number(b.featured ?? false) - Number(a.featured ?? false),
);

const totalProjects = allProjects.length;

// Flatten skills for easy lookup
const skillIcons = skillGroups.flatMap(group => group.items);
const getSkillIcon = (name: string) => {
    const searchName = name.trim().toLowerCase();
    
    // 1. Try exact match first (case-insensitive)
    let skill = skillIcons.find(s => s.name.toLowerCase() === searchName);
    if (skill) return skill.icon;

    // 2. Try matching without version numbers (e.g., "React 19" -> "React")
    const nameWithoutVersion = searchName.replace(/\s\d+.*$/, '').trim();
    skill = skillIcons.find(s => s.name.toLowerCase() === nameWithoutVersion);
    if (skill) return skill.icon;

    // 3. Try to find the longest matching skill name contained in the search string
    // This handles "React Router" matching "React Router" instead of just "React"
    // Sort by length descending to get the most specific match first
    const sortedSkills = [...skillIcons].toSorted((a, b) => b.name.length - a.name.length);
    skill = sortedSkills.find(s => {
        const skillName = s.name.toLowerCase();
        // Avoid matching very short names like "Go" inside other words unless it's a standalone word
        if (skillName.length <= 3) {
            const regex = new RegExp(`\\b${skillName}\\b`, 'i');
            return regex.test(searchName);
        }
        return searchName.includes(skillName);
    });
    
    return skill?.icon;
};
---

<section id="vdf-projects" class="px-8 py-32 lg:px-24 scroll-mt-20">
	<div class="flex flex-col xl:flex-row items-start xl:items-end justify-between mb-16 vdf-reveal gap-12">
		<div class="max-w-2xl">
			<p class="mb-4 font-mono text-xs sm:text-sm tracking-[0.2em] sm:tracking-[0.3em] text-red-500 uppercase font-semibold">
				<span class="text-red-500/60">01 —</span> Selected Works
			</p>
			<h2 class="text-5xl font-black tracking-tighter uppercase sm:text-6xl md:text-8xl leading-[0.9]">
				Projects
			</h2>
		</div>

        <div class="flex flex-col gap-6 w-full xl:w-auto">
            <div class="flex items-center justify-between xl:justify-end gap-4">
                <p class="font-mono text-[11px] tracking-widest text-[var(--text-muted)] uppercase">
                    Filter by Category
                </p>
                <div class="h-px w-12 bg-[var(--border-strong)] hidden xl:block"></div>
                <p class="font-mono text-[11px] tracking-widest text-[var(--text-muted)] uppercase">
                    {String(totalProjects).padStart(2, "0")} Total
                </p>
            </div>
            <div class="flex flex-wrap gap-2">
                {categories.map((cat) => (
                    <button
                        type="button"
                        class="filter-btn group relative px-5 py-2.5 rounded-full border border-[var(--border-strong)] text-[var(--text-muted)] font-mono text-[11px] uppercase tracking-widest transition-all duration-500 hover:border-red-500/40 hover:text-[var(--text-primary)]"
                        data-category={cat}
                        aria-pressed={cat === "All" ? "true" : "false"}
                    >
                        <span class="relative z-10">{cat}</span>
                        <div class="absolute inset-0 rounded-full bg-red-500 scale-0 transition-transform duration-500 ease-out -z-0 group-aria-pressed:scale-100"></div>
                        <span class="absolute inset-0 rounded-full border border-red-500 opacity-0 group-aria-pressed:opacity-100 transition-opacity"></span>
                    </button>
                ))}
            </div>
        </div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 project-grid items-start">
		{allProjects.map((project) => (
			<div
				class:list={[
					"project-card group relative flex flex-col bg-[var(--bg-card)] border border-[var(--border-hairline)] rounded-3xl p-8 hover:bg-[var(--bg-card-hover)] transition-all duration-700 ease-out vdf-reveal overflow-hidden h-full",
					project.featured && "md:col-span-2 xl:col-span-2 featured-card",
				]}
				data-category={project.parentCategory}
				data-featured={project.featured ? "true" : "false"}
				style={`--project-color: ${project.color}`}
			>
                {/* Background Glow */}
                <div class="absolute top-0 right-0 w-64 h-64 -mr-32 -mt-32 bg-[var(--project-color)] opacity-0 group-hover:opacity-[0.07] blur-[100px] transition-all duration-1000 rounded-full pointer-events-none group-[.is-active]:opacity-[0.07]"></div>
                
                <div class="flex items-start justify-between mb-8">
                    <div class="flex flex-col">
                        <div class="flex items-center gap-3 mb-1">
                            <span class="font-mono text-sm font-bold text-red-500">{project.id}</span>
                            {project.featured && (
                                <span class="flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-red-500/30 bg-red-500/5 font-mono text-[9px] uppercase tracking-[0.2em] text-red-400 font-bold">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
                                    Featured
                                </span>
                            )}
                        </div>
                        <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--text-faint)] font-bold group-hover:text-[var(--text-tertiary)] transition-colors group-[.is-active]:text-[var(--text-tertiary)]">
                            {project.category}
                        </span>
                    </div>
                    
                    <div class="flex gap-3">
                        <a
                            href={project.repo}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="p-2.5 rounded-full bg-[var(--fill-tint-5)] border border-[var(--border-hairline)] hover:border-[var(--border-strong)] hover:bg-[var(--fill-tint-10)] transition-all duration-300 group/repo"
                            title="View Repository"
                        >
                            <img
                                src="/icons/github.svg"
                                alt="GitHub"
                                class="w-4 h-4 opacity-50 group-hover/repo:opacity-100 icon-adaptive transition-opacity"
                            />
                        </a>
                        {hasLiveUrl(project.url) && (
                            <a
                                href={project.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="p-2.5 rounded-full bg-[var(--fill-tint-5)] border border-[var(--border-hairline)] hover:border-[var(--border-strong)] hover:bg-[var(--fill-tint-10)] transition-all duration-300 group/link"
                                title="Visit Website"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-50 group-hover/link:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                                </svg>
                            </a>
                        )}
                    </div>
                </div>

                <div class="mb-6">
                    {hasLiveUrl(project.url) ? (
                        <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-block group/title"
                        >
                            <h3 class="text-3xl md:text-4xl font-black tracking-tighter uppercase transition-all duration-500 leading-none project-title">
                                {project.title}
                            </h3>
                            <div class="h-px w-0 bg-[var(--project-color)] transition-all duration-500 group-hover:w-full group-[.is-active]:w-full mt-2"></div>
                        </a>
                    ) : (
                        <div class="inline-block">
                            <h3 class="text-3xl md:text-4xl font-black tracking-tighter uppercase transition-all duration-500 leading-none project-title">
                                {project.title}
                            </h3>
                            <p class="mt-2 text-[11px] font-mono uppercase tracking-[0.2em] text-[var(--text-muted)]">
                                Repository available
                            </p>
                        </div>
                    )}
                </div>

                <p class="text-[var(--text-tertiary)] text-sm leading-relaxed mb-10 grow font-medium">
                    {project.description}
                </p>

                <div class="mt-auto">
                    <div class="flex flex-wrap gap-2 mb-2">
                        {project.tech.split(" · ").map((t) => {
                            const icon = getSkillIcon(t);
                            return (
                                <span class="flex items-center gap-1.5 px-3 py-1.5 text-[10px] font-mono tracking-widest uppercase border border-[var(--border-hairline)] bg-[var(--fill-tint-2)] rounded-full text-[var(--text-muted)] group-hover:border-[var(--border-muted)] group-hover:text-[var(--text-secondary)] group-[.is-active]:border-[var(--border-muted)] group-[.is-active]:text-[var(--text-secondary)] transition-all duration-500">
                                    {icon && (
                                        <Icon 
                                            name={icon} 
                                            class="w-3 h-3 grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 group-[.is-active]:grayscale-0 group-[.is-active]:opacity-100 transition-all duration-500"
                                        />
                                    )}
                                    {t}
                                </span>
                            );
                        })}
                    </div>
                </div>

                {/* Corner Decoration */}
                <div class="absolute bottom-0 right-0 w-12 h-12 bg-gradient-to-br from-transparent to-[var(--fill-tint-5)] rounded-tl-3xl"></div>
			</div>
		))}
	</div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    const filterBtns = document.querySelectorAll('.filter-btn');
    const projectCards = document.querySelectorAll('.project-card');
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const showCard = (card: Element) => {
        (card as HTMLElement).style.display = 'flex';

        if (prefersReducedMotion.matches) {
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'none';
            return;
        }

        gsap.to(card, {
            opacity: 1,
            scale: 1,
            y: 0,
            duration: 0.5,
            ease: "power3.out",
            clearProps: "all"
        });
    };

    const hideCard = (card: Element) => {
        if (prefersReducedMotion.matches) {
            (card as HTMLElement).style.display = 'none';
            ScrollTrigger.refresh();
            return;
        }

        gsap.to(card, {
            opacity: 0,
            scale: 0.9,
            y: 20,
            duration: 0.3,
            ease: "power2.in",
            onComplete: () => {
                (card as HTMLElement).style.display = 'none';
                ScrollTrigger.refresh();
            }
        });
    };

    // Filter logic
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = btn.getAttribute('data-category');

            filterBtns.forEach(b => {
                b.setAttribute('aria-pressed', 'false');
            });
            btn.setAttribute('aria-pressed', 'true');

            projectCards.forEach(card => {
                const cardCat = card.getAttribute('data-category');
                const isVisible = category === 'All' || cardCat === category;

                if (isVisible) {
                    showCard(card);
                } else {
                    hideCard(card);
                }
            });

            const refreshDelay = prefersReducedMotion.matches ? 0 : 550;
            setTimeout(() => {
                ScrollTrigger.refresh();
            }, refreshDelay);
        });
    });

    // Mobile Scroll Activation using Intersection Observer
    const observerOptions = {
        threshold: 0.7,
        rootMargin: "-10% 0px -10% 0px"
    };

    let mobileObserver: IntersectionObserver | null = null;

    const setupMobileObserver = () => {
        const isMobile = window.innerWidth < 768;

        if (isMobile && !mobileObserver) {
            mobileObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    entry.target.classList.toggle('is-active', entry.isIntersecting);
                });
            }, observerOptions);
            projectCards.forEach(card => mobileObserver!.observe(card));
        } else if (!isMobile && mobileObserver) {
            mobileObserver.disconnect();
            mobileObserver = null;
            projectCards.forEach(card => card.classList.remove('is-active'));
        }
    };

    setupMobileObserver();
    window.addEventListener("resize", setupMobileObserver, { passive: true });

</script>

<style>
    .project-card {
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
    }
    
    .filter-btn[aria-pressed="true"] {
        color: var(--text-primary);
    }

    .project-grid {
        align-items: stretch;
    }

    .project-title {
        color: var(--text-primary);
        -webkit-text-stroke: 1px var(--outline-stroke-faint);
        transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
    }

    .featured-card .project-title {
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        line-height: 0.9;
    }

    .featured-card p.grow,
    .featured-card .grow {
        font-size: 0.95rem;
        max-width: 60ch;
    }

    .featured-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(135deg, var(--project-color) 0%, transparent 40%, transparent 60%, var(--project-color) 100%);
        opacity: 0.25;
        -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
        -webkit-mask-composite: xor;
                mask-composite: exclude;
        pointer-events: none;
        transition: opacity 0.5s ease;
    }

    .featured-card:hover::before {
        opacity: 0.5;
    }

    /* Hover State (Desktop) */
    .project-card:hover .project-title {
        color: var(--project-color);
        -webkit-text-stroke: 0px transparent;
        transform: translateX(0.75rem);
    }

    /* Active State (Mobile Scroll) */
    @media (max-width: 767px) {
        .project-card.is-active .project-title {
            color: var(--project-color);
            -webkit-text-stroke: 0px transparent;
            transform: translateX(0.5rem);
        }
    }
</style>
