---
import { skills as skillGroups } from "../data/skills";

interface Project {
	id: string;
	title: string;
	category: string;
	color: string;
	tech: string;
	description: string;
	url: string;
	repo: string;
}

interface ProjectCategory {
	name: string;
	projects: Project[];
}

interface Props {
	projectCategories?: ProjectCategory[];
    projects?: Project[];
}

const { projectCategories, projects } = Astro.props;

// Flatten the projects and add parent category for filtering
// Handle both categorized and flat project lists
let allProjects: (Project & { parentCategory: string })[] = [];
let categories: string[] = ["All"];

if (projectCategories && Array.isArray(projectCategories)) {
    allProjects = projectCategories.flatMap(cat => 
        cat.projects.map(p => ({ 
            ...p, 
            parentCategory: cat.name 
        }))
    );
    categories = ["All", ...projectCategories.map(cat => cat.name)];
} else if (projects && Array.isArray(projects)) {
    // If a flat list is provided, group by their internal category for filtering
    allProjects = projects.map(p => ({
        ...p,
        parentCategory: p.category
    }));
    const uniqueCategories = [...new Set(projects.map(p => p.category))];
    categories = ["All", ...uniqueCategories];
}

const totalProjects = allProjects.length;

// Flatten skills for easy lookup
const skillIcons = skillGroups.flatMap(group => group.items);
const getSkillIcon = (name: string) => {
    const searchName = name.trim().toLowerCase();
    
    // 1. Try exact match first (case-insensitive)
    let skill = skillIcons.find(s => s.name.toLowerCase() === searchName);
    if (skill) return skill.icon;

    // 2. Try matching without version numbers (e.g., "React 19" -> "React")
    const nameWithoutVersion = searchName.replace(/\s\d+.*$/, '').trim();
    skill = skillIcons.find(s => s.name.toLowerCase() === nameWithoutVersion);
    if (skill) return skill.icon;

    // 3. Try to find the longest matching skill name contained in the search string
    // This handles "React Router" matching "React Router" instead of just "React"
    // Sort by length descending to get the most specific match first
    const sortedSkills = [...skillIcons].sort((a, b) => b.name.length - a.name.length);
    skill = sortedSkills.find(s => {
        const skillName = s.name.toLowerCase();
        // Avoid matching very short names like "Go" inside other words unless it's a standalone word
        if (skillName.length <= 3) {
            const regex = new RegExp(`\\b${skillName}\\b`, 'i');
            return regex.test(searchName);
        }
        return searchName.includes(skillName);
    });
    
    return skill?.icon;
};
---

<section id="vdf-projects" class="px-8 py-32 lg:px-24 scroll-mt-20">
	<div class="flex flex-col xl:flex-row items-start xl:items-end justify-between mb-16 vdf-reveal gap-12">
		<div class="max-w-2xl">
			<p class="mb-4 font-mono text-sm tracking-[0.3em] text-red-500 uppercase font-semibold">
				Selected Works
			</p>
			<h2 class="text-6xl font-black tracking-tighter uppercase md:text-8xl leading-[0.9]">
				Projects
			</h2>
		</div>

        <div class="flex flex-col gap-6 w-full xl:w-auto">
            <div class="flex items-center justify-between xl:justify-end gap-4">
                <p class="font-mono text-xs tracking-widest text-neutral-500 uppercase">
                    Filter by Category
                </p>
                <div class="h-px w-12 bg-neutral-800 hidden xl:block"></div>
                <p class="font-mono text-xs tracking-widest text-neutral-500 uppercase">
                    {String(totalProjects).padStart(2, "0")} Total
                </p>
            </div>
            <div class="flex flex-wrap gap-2">
                {categories.map((cat) => (
                    <button
                        class="filter-btn group relative px-5 py-2.5 rounded-full border border-neutral-800 text-neutral-500 font-mono text-[10px] uppercase tracking-widest transition-all duration-500 hover:border-red-500/40 hover:text-white"
                        data-category={cat}
                        aria-pressed={cat === "All" ? "true" : "false"}
                    >
                        <span class="relative z-10">{cat}</span>
                        <div class="absolute inset-0 rounded-full bg-red-500 scale-0 transition-transform duration-500 ease-out -z-0 group-aria-pressed:scale-100"></div>
                        <span class="absolute inset-0 rounded-full border border-red-500 opacity-0 group-aria-pressed:opacity-100 transition-opacity"></span>
                    </button>
                ))}
            </div>
        </div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 gap-8 project-grid items-start">
		{allProjects.map((project) => (
			<div
				class="project-card group relative flex flex-col bg-[#0d0d0d]/50 border border-white/5 rounded-3xl p-8 hover:bg-[#121212] transition-all duration-700 ease-out vdf-reveal overflow-hidden h-full"
				data-category={project.parentCategory}
				style={`--project-color: ${project.color}`}
			>
                {/* Background Glow */}
                <div class="absolute top-0 right-0 w-64 h-64 -mr-32 -mt-32 bg-[var(--project-color)] opacity-0 group-hover:opacity-[0.07] blur-[100px] transition-all duration-1000 rounded-full pointer-events-none group-[.is-active]:opacity-[0.07]"></div>
                
                <div class="flex items-start justify-between mb-8">
                    <div class="flex flex-col">
                        <span class="font-mono text-sm font-bold text-red-500 mb-1">{project.id}</span>
                        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-neutral-600 font-bold group-hover:text-neutral-400 transition-colors group-[.is-active]:text-neutral-400">
                            {project.category}
                        </span>
                    </div>
                    
                    <div class="flex gap-3">
                        <a
                            href={project.repo}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="p-2.5 rounded-full bg-white/5 border border-white/5 hover:border-white/20 hover:bg-white/10 transition-all duration-300 group/repo"
                            title="View Repository"
                        >
                            <img
                                src="/icons/github.svg"
                                alt="GitHub"
                                class="w-4 h-4 opacity-50 group-hover/repo:opacity-100 invert transition-opacity"
                            />
                        </a>
                        <a
                            href={project.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="p-2.5 rounded-full bg-white/5 border border-white/5 hover:border-white/20 hover:bg-white/10 transition-all duration-300 group/link"
                            title="Visit Website"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-50 group-hover/link:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                            </svg>
                        </a>
                    </div>
                </div>

                <div class="mb-6">
                    <a href={project.url} target="_blank" class="inline-block group/title">
                        <h3 class="text-3xl md:text-4xl font-black tracking-tighter uppercase transition-all duration-500 leading-none project-title">
                            {project.title}
                        </h3>
                        <div class="h-px w-0 bg-[var(--project-color)] transition-all duration-500 group-hover:w-full group-[.is-active]:w-full mt-2"></div>
                    </a>
                </div>

                <p class="text-neutral-400 text-sm leading-relaxed mb-10 grow font-medium">
                    {project.description}
                </p>

                <div class="mt-auto">
                    <div class="flex flex-wrap gap-2 mb-2">
                        {project.tech.split(" · ").map((t) => {
                            const icon = getSkillIcon(t);
                            return (
                                <span class="flex items-center gap-1.5 px-3 py-1.5 text-[9px] font-mono tracking-widest uppercase border border-white/5 bg-white/[0.02] rounded-full text-neutral-500 group-hover:border-white/10 group-hover:text-neutral-300 group-[.is-active]:border-white/10 group-[.is-active]:text-neutral-300 transition-all duration-500">
                                    {icon && (
                                        <img 
                                            src={icon} 
                                            alt="" 
                                            class="w-3 h-3 grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 group-[.is-active]:grayscale-0 group-[.is-active]:opacity-100 transition-all duration-500"
                                        />
                                    )}
                                    {t}
                                </span>
                            );
                        })}
                    </div>
                </div>

                {/* Corner Decoration */}
                <div class="absolute bottom-0 right-0 w-12 h-12 bg-gradient-to-br from-transparent to-white/[0.03] rounded-tl-3xl"></div>
			</div>
		))}
	</div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    const filterBtns = document.querySelectorAll('.filter-btn');
    const projectCards = document.querySelectorAll('.project-card');

    // Filter logic
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = btn.getAttribute('data-category');
            
            filterBtns.forEach(b => {
                b.setAttribute('aria-pressed', 'false');
                b.querySelector('span')?.classList.remove('text-white');
            });
            btn.setAttribute('aria-pressed', 'true');
            btn.querySelector('span')?.classList.add('text-white');

            projectCards.forEach(card => {
                const cardCat = card.getAttribute('data-category');
                const isVisible = category === 'All' || cardCat === category;

                if (isVisible) {
                    (card as HTMLElement).style.display = 'flex';
                    gsap.to(card, {
                        opacity: 1,
                        scale: 1,
                        y: 0,
                        duration: 0.5,
                        ease: "power3.out",
                        clearProps: "all"
                    });
                } else {
                    gsap.to(card, {
                        opacity: 0,
                        scale: 0.9,
                        y: 20,
                        duration: 0.3,
                        ease: "power2.in",
                        onComplete: () => {
                            (card as HTMLElement).style.display = 'none';
                            ScrollTrigger.refresh();
                        }
                    });
                }
            });

            setTimeout(() => {
                ScrollTrigger.refresh();
            }, 550);
        });
    });

    // Mobile Scroll Activation using Intersection Observer
    if (window.innerWidth < 768) {
        const observerOptions = {
            threshold: 0.7,
            rootMargin: "-10% 0px -10% 0px"
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-active');
                } else {
                    entry.target.classList.remove('is-active');
                }
            });
        }, observerOptions);

        projectCards.forEach(card => observer.observe(card));
    }

    // Initialize the "All" button style
    document.querySelector('.filter-btn[data-category="All"] span')?.classList.add('text-white');
</script>

<style>
    .project-card {
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
    }
    
    .filter-btn[aria-pressed="true"] {
        color: white;
    }

    .project-grid {
        align-items: stretch;
    }

    .project-title {
        color: white;
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);
        transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
    }

    /* Hover State (Desktop) */
    .project-card:hover .project-title {
        color: var(--project-color);
        -webkit-text-stroke: 0px transparent;
        transform: translateX(0.75rem);
    }

    /* Active State (Mobile Scroll) */
    @media (max-width: 767px) {
        .project-card.is-active .project-title {
            color: var(--project-color);
            -webkit-text-stroke: 0px transparent;
            transform: translateX(0.5rem);
        }
    }
</style>
